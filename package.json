{
  "name": "kombatix-web",
  "version": "0.1.0",
  "private": true,
  "description": "Marketing site for kombatix.io — static Next.js on Firebase Hosting",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint",
    "check": "tsc --noEmit",
    "preview": "firebase hosting:channel:deploy preview --expires 7d",
    "deploy": "npm run build && firebase deploy --only hosting,functions",
    "emulators": "firebase emulators:start",
    "postinstall": "cd functions && npm install"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.400.0",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "latest",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  }
}
