# ==============================
# Kombatix Web — Environment Vars
# ==============================

# Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Site URL (used in canonical tags and sitemap)
NEXT_PUBLIC_SITE_URL=https://kombatix.io

# ==============================
# SERVER-SIDE ONLY — set via Firebase Secret Manager, NEVER commit
# ==============================
# Set with:
#   firebase functions:secrets:set HUBSPOT_PORTAL_ID
#   firebase functions:secrets:set HUBSPOT_FORM_GUID
#
# The partner inquiry Cloud Function reads these at runtime.
# Do NOT put them in .env.local — they belong in Firebase Secret Manager.
