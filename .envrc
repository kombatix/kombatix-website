# Kombatix Website — repo-scoped environment pins
#
# This file pins the gcloud configuration, GCP project, Firebase project,
# and account context for EVERY shell that loads this directory.
#
# Why:
#   This machine has 14+ gcloud configurations and 4+ gcloud-authenticated
#   accounts across PeopleFinders, Big Fat Dad, Kombatix, and others. The
#   `gcloud` CLI picks up whatever configuration is "ambiently active,"
#   which drifts silently across parallel Claude Code / VS Code sessions.
#   These env vars override ambient state for anything started in this repo.
#
# How:
#   Option A (recommended) — install direnv (https://direnv.net):
#     winget install direnv.direnv   # Windows
#     # Then restart your shell, `cd` into this repo, and run:
#     direnv allow .
#   After that, every shell/session that cd's into this repo auto-loads
#   these pins, and auto-unloads them when you cd away.
#
#   Option B — manual: at session start, run `source .envrc` from bash.
#
# Expected values are hard-coded here and in scripts/verify-context.sh.
# Do NOT change without explicit user confirmation — see CLAUDE.md section 1.

# GCP / Firebase project
export GOOGLE_CLOUD_PROJECT=kombatix-website
export GCLOUD_PROJECT=kombatix-website
export CLOUDSDK_CORE_PROJECT=kombatix-website
export FIREBASE_PROJECT=kombatix-website

# gcloud account + named configuration
#
# CLOUDSDK_ACTIVE_CONFIG_NAME tells gcloud which named configuration to use,
# overriding whatever is ambiently active. The `kombatix` configuration must
# exist on this machine; create it with:
#
#   gcloud config configurations create kombatix --no-activate
#   gcloud config configurations activate kombatix
#   gcloud config set account operations@kombatix.io
#   gcloud config set project kombatix-website
#
# `operations@kombatix.io` must already be authenticated — verify with
# `gcloud auth list`; if not present, run `gcloud auth login operations@kombatix.io`.
export CLOUDSDK_ACTIVE_CONFIG_NAME=kombatix
export CLOUDSDK_CORE_ACCOUNT=operations@kombatix.io

# GitHub — pin the git-operations host. The active `gh` user is separately
# controlled by `gh auth switch -u kombatix`, and this repo's .git/config
# pins `credential.https://github.com.username=kombatix` to force pushes
# through the kombatix credential regardless of which gh user is active.
export GH_HOST=github.com

# Optional: bypass escape hatch — do not set in normal operation.
# Setting this to 1 causes scripts/verify-context.sh to pass without checking.
# Useful only when you need to run context-sensitive scripts in an intentionally
# drifted state (e.g., inspecting another project's Firebase from this shell).
# unset KOMBATIX_SKIP_CONTEXT_CHECK
